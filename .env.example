# 前端对外端口（容器内 backend 仍是 8418，nginx 已下线，前端直接由 Go 嵌入 serve）
HTTP_PORT=8080

# 拉取的镜像 tag
IMAGE_TAG=edge

# Backend 运行模式 / 日志等级
SERVER_MODE=release
LOG_LEVEL=info

# 默认 SQLite 单文件。docker-compose.yml 已内置同样配置；这里主要给本地直跑或自定义覆盖用。
DATABASE_DRIVER=sqlite
DATABASE_PATH=/app/data/relaydeck.db

# 叠加 docker-compose.mysql.yml 时使用这组 MySQL 参数
MYSQL_DATABASE=relaydeck
MYSQL_USER=relaydeck
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_PORT=33069

# 主密钥（任意长度，至少 32 字节随机串），用于 AES-GCM 加密敏感字段。
# **必填** — 修改后既有数据无法解密，请务必妥善保存。
APP_SECRET=please-change-me-to-a-long-random-secret-32bytes-min

# 鉴权开关。首次启动且 data/config.yaml 尚无 auth 配置时用于初始化。
# 公网暴露请设 AUTH_ENABLED=true 并同时填好 ADMIN_PASSWORD；之后在系统设置修改即可持久生效。
AUTH_ENABLED=false

# 首次初始化的后台登录账号 / 密码。配置文件保存 auth 后，重启以系统设置中的值为准。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# token 签名密钥；留空时回退使用 APP_SECRET
AUTH_TOKEN_SECRET=
